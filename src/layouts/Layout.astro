---
import { ClientRouter } from "astro:transitions";
import ThemeSelector from "../components/ThemeSelector.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  image?: string;
}

const {
  title = "Andrii Shupta",
  description = "Andrii Shupta is a full-stack web developer and AI-first software engineer building apps, landing pages, back-end services, prototypes, dashboards, integrations, and internal tools.",
  pathname = Astro.url.pathname,
  image = "/favicon.svg",
} = Astro.props;
const siteUrl = new URL(pathname, "https://andriishupta.dev");
const imageUrl = new URL(image, siteUrl);
const pageTitle =
  title === "Andrii Shupta" ? title : `${title} | Andrii Shupta`;
const keywords = [
  "Andrii Shupta",
  "full-stack web developer",
  "frontend web developer",
  "backend web developer",
  "React developer",
  "Next.js developer",
  "Node.js developer",
  "TypeScript developer",
  "Supabase expert",
  "AI integration expert",
  "vibe engineer",
  "AI-first development",
].join(", ");
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="author" content="Andrii Shupta" />
        <meta name="creator" content="Andrii Shupta" />
        <meta name="robots" content="index, follow" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <link rel="canonical" href={siteUrl} />
        <meta name="description" content={description} />
        <meta name="keywords" content={keywords} />
        <meta
            name="theme-color"
            content="#fbf7ef"
            media="(prefers-color-scheme: light)"
        />
        <meta
            name="theme-color"
            content="#0d0f12"
            media="(prefers-color-scheme: dark)"
        />
        <meta name="generator" content={Astro.generator} />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={siteUrl} />
        <meta property="og:site_name" content="Andrii Shupta" />
        <meta property="og:locale" content="en_US" />
        <meta property="og:image" content={imageUrl} />
        <meta property="og:image:alt" content="Andrii Shupta" />
        <meta name="twitter:card" content="summary" />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={imageUrl} />
        <title>{pageTitle}</title>
        <script is:inline>
            (() => {
                const preference = localStorage.getItem("theme");
                const systemDark = window.matchMedia(
                    "(prefers-color-scheme: dark)",
                ).matches;
                const shouldUseDark =
                    preference === "dark" || (!preference && systemDark);
                document.documentElement.classList.toggle(
                    "dark",
                    shouldUseDark,
                );
                document.documentElement.dataset.theme = preference || "system";
            })();
        </script>
        <ClientRouter />
    </head>
    <body class="min-h-screen">
        <ThemeSelector />
        <slot />
    </body>
</html>
