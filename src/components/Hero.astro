---
import ArrowDown from "@lucide/astro/icons/arrow-down";
import ArrowUpRight from "@lucide/astro/icons/arrow-up-right";
import BriefcaseBusiness from "@lucide/astro/icons/briefcase-business";
import FileDown from "@lucide/astro/icons/file-down";
import PenLine from "@lucide/astro/icons/pen-line";
import { copy } from "../copy";
import BrandIcon from "./BrandIcon.astro";

const { header, intro } = copy.mainPage;
---

<main class="hero snap-section" data-hero>
  <div class="hero__content">
    <div class="hero__identity">
      <h1 class="hero__name" id="hero-title">
        {
          header.nameLines.map((line) => (
            <span class="hero__name-line-wrap">
              <span class="hero__name-line" data-hero-line>{line}</span>
            </span>
          ))
        }
      </h1>

      <nav class="social-links" aria-label={header.linksLabel} data-hero-links>
        {
          header.links.map((link) => (
            <a
              class="social-link"
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
            >
              {"brand" in link && <BrandIcon name={link.brand} class="social-link__icon" />}
              {"icon" in link && link.icon === "upwork" && <BriefcaseBusiness class="social-link__icon" />}
              {"icon" in link && link.icon === "cv" && <FileDown class="social-link__icon" />}
              {"icon" in link && link.icon === "blog" && <PenLine class="social-link__icon" />}
              <span>{link.label}</span>
              <ArrowUpRight class="social-link__arrow" />
            </a>
          ))
        }
      </nav>
    </div>

    <div class="hero__profile" data-hero-copy>
      <h2 class="hero__role">
        {intro.heading}
      </h2>
      <p class="hero__statement">{intro.description}</p>
    </div>
  </div>

  <a class="scroll-cue" href="#about" aria-label={intro.scrollAriaLabel}>
    <span>{intro.scrollLabel}</span>
    <ArrowDown />
  </a>
</main>

<script>
  import { gsap } from "gsap";

  const runHeroIntro = () => {
    const hero = document.querySelector<HTMLElement>("[data-hero]");
    if (!hero || hero.dataset.introReady === "true") return;
    hero.dataset.introReady = "true";

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      hero.dataset.introComplete = "true";
      return;
    }

    const timeline = gsap.timeline({
      defaults: { ease: "power4.out" },
      onComplete: () => {
        hero.dataset.introComplete = "true";
      },
    });
    timeline
      .fromTo(
        hero.querySelectorAll("[data-hero-line]"),
        { yPercent: 112 },
        { yPercent: 0, duration: 0.82, stagger: 0.08 },
      )
      .fromTo(
        hero.querySelector("[data-hero-copy]"),
        { opacity: 0, y: 22 },
        { opacity: 1, y: 0, duration: 0.68 },
        "-=0.56",
      )
      .fromTo(
        hero.querySelector("[data-hero-links]"),
        { opacity: 0, y: 16 },
        { opacity: 1, y: 0, duration: 0.58 },
        "-=0.48",
      );
  };

  runHeroIntro();
</script>
