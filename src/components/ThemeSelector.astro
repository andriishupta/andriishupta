---
import { Icon } from "astro-icon/components";

const iconClass = "cursor-pointer size-4.5 text-light-muted dark:text-muted";
const buttonClass =
  "inline-grid size-9 place-items-center rounded-full text-light-muted transition hover:bg-light-ink/[0.06] hover:text-light-ink data-[active=true]:bg-light-ink/[0.08] data-[active=true]:text-light-ink dark:text-muted dark:hover:bg-paper/[0.06] dark:hover:text-paper dark:data-[active=true]:bg-paper/[0.08] dark:data-[active=true]:text-paper";
---

<div class="fixed right-4 top-4 z-10" data-theme-selector>
	<button
		class="inline-grid size-10 cursor-pointer place-items-center rounded-full border border-light-ink/10 bg-light-paper/70 text-light-muted shadow-sm shadow-light-ink/5 backdrop-blur-md transition hover:bg-light-paper hover:text-light-ink dark:border-paper/10 dark:bg-ink-soft/70 dark:text-muted dark:shadow-black/20 dark:hover:bg-ink-soft dark:hover:text-paper"
		type="button"
		aria-label="Open theme selector"
		aria-expanded="false"
		data-theme-trigger
	>
		<span data-theme-current="system">
			<Icon name="fa6-solid:desktop" class={iconClass} />
		</span>
		<span class="hidden" data-theme-current="light">
			<Icon name="fa6-solid:sun" class={iconClass} />
		</span>
		<span class="hidden" data-theme-current="dark">
			<Icon name="fa6-solid:moon" class={iconClass} />
		</span>
	</button>

	<div
		class="absolute right-0 mt-2 hidden rounded-full border border-light-ink/10 bg-light-paper/80 p-1 shadow-sm shadow-light-ink/5 backdrop-blur-md dark:border-paper/10 dark:bg-ink-soft/80 dark:shadow-black/20"
		data-theme-menu
	>
		<button
			class={buttonClass}
			type="button"
			data-theme-option="system"
			aria-label="Use system theme"
			aria-pressed="false"
			title="System"
		>
			<Icon name="fa6-solid:desktop" class={iconClass} />
		</button>
		<button
			class={buttonClass}
			type="button"
			data-theme-option="light"
			aria-label="Use light theme"
			aria-pressed="false"
			title="Light"
		>
			<Icon name="fa6-solid:sun" class={iconClass} />
		</button>
		<button
			class={buttonClass}
			type="button"
			data-theme-option="dark"
			aria-label="Use dark theme"
			aria-pressed="false"
			title="Dark"
		>
			<Icon name="fa6-solid:moon" class={iconClass} />
		</button>
	</div>
</div>

<script is:inline>
	(() => {
		const storageKey = 'theme';
		const systemQuery = window.matchMedia('(prefers-color-scheme: dark)');
		const root = document.querySelector('[data-theme-selector]');
		if (!root) return;

		const trigger = root.querySelector('[data-theme-trigger]');
		const menu = root.querySelector('[data-theme-menu]');
		const buttons = root.querySelectorAll('[data-theme-option]');
		const currentIcons = root.querySelectorAll('[data-theme-current]');

		const getPreference = () => localStorage.getItem(storageKey) || 'system';
		const resolveTheme = (preference) => {
			if (preference === 'dark' || preference === 'light') {
				return preference;
			}

			return systemQuery.matches ? 'dark' : 'light';
		};
		const setMenuOpen = (open) => {
			menu?.classList.toggle('hidden', !open);
			trigger?.setAttribute('aria-expanded', String(open));
		};

		const applyTheme = (preference = getPreference()) => {
			const resolvedTheme = resolveTheme(preference);
			document.documentElement.classList.toggle('dark', resolvedTheme === 'dark');
			document.documentElement.dataset.theme = preference;

			buttons.forEach((button) => {
				const isActive = button.dataset.themeOption === preference;
				button.dataset.active = String(isActive);
				button.setAttribute('aria-pressed', String(isActive));
			});

			currentIcons.forEach((icon) => {
				icon.classList.toggle('hidden', icon.dataset.themeCurrent !== preference);
			});
		};

		trigger?.addEventListener('click', () => {
			setMenuOpen(menu?.classList.contains('hidden') ?? true);
		});

		buttons.forEach((button) => {
			button.addEventListener('click', () => {
				const preference = button.dataset.themeOption;

				if (!preference || preference === 'system') {
					localStorage.removeItem(storageKey);
					applyTheme('system');
					setMenuOpen(false);
					return;
				}

				localStorage.setItem(storageKey, preference);
				applyTheme(preference);
				setMenuOpen(false);
			});
		});

		document.addEventListener('click', (event) => {
			if (!root.contains(event.target)) {
				setMenuOpen(false);
			}
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') {
				setMenuOpen(false);
			}
		});

		systemQuery.addEventListener('change', () => {
			if (!localStorage.getItem(storageKey)) {
				applyTheme('system');
			}
		});

		document.addEventListener('astro:page-load', () => applyTheme());
		applyTheme();
	})();
</script>
