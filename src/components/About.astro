---
import ArrowDown from "@lucide/astro/icons/arrow-down";
import Atom from "@lucide/astro/icons/atom";
import Database from "@lucide/astro/icons/database";
import FileCode from "@lucide/astro/icons/file-code";
import Server from "@lucide/astro/icons/server";
import { copy } from "../copy";

const { about } = copy.mainPage;
const technologyIcons = {
  code: FileCode,
  react: Atom,
  server: Server,
  database: Database,
};
---

<section class="about snap-section" id="about" aria-labelledby="about-title">
  <div class="about__inner">
    <div class="about__heading">
      <h2 id="about-title">{about.heading}</h2>
      <ul class="about__services" aria-label={about.areasLabel}>
        {about.areas.map((area) => <li>{area}</li>)}
      </ul>

      <div class="technology-block">
        <h3>{about.coreStack.heading}</h3>
        <ul class="technology-list" aria-label={about.coreStack.listLabel}>
          {
            about.coreStack.technologies.map(({ name, icon }) => {
              const Icon = technologyIcons[icon];
              return (
                <li>
                  <Icon aria-hidden="true" />
                  <span>{name}</span>
                </li>
              );
            })
          }
        </ul>
      </div>

      <p class="about__degree">{about.degree}</p>
    </div>

    <div class="about__content">
      <div class="about__copy">
        <p>{about.description}</p>
      </div>

      <div class="about__notes">
        {
          about.additional.map((item) => (
            <p><strong>{item.label}</strong> {item.text}</p>
          ))
        }
      </div>

      <p class="about__resources">
        {about.linksIntro}{" "}
        {
          about.links.map((link, index) => (
            <>
              {index > 0 && (index === about.links.length - 1 ? ", and " : ", ")}
              {link.before}{" "}
              <a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
            </>
          ))
        }.
      </p>
    </div>
  </div>

  <a
    class="section-scroll-cue"
    href="#experience"
    aria-label={about.scrollAriaLabel}
  >
    <span>{about.scrollLabel}</span>
    <ArrowDown aria-hidden="true" />
  </a>
</section>
