<script>
  import { gsap } from "gsap";
  import { ScrollToPlugin } from "gsap/ScrollToPlugin";

  gsap.registerPlugin(ScrollToPlugin);

  const initSectionSnap = () => {
    const root = document.documentElement;
    const sections = Array.from(
      document.querySelectorAll<HTMLElement>(".snap-section"),
    );
    const usesTouch =
      window.matchMedia("(pointer: coarse), (hover: none)").matches ||
      navigator.maxTouchPoints > 0;

    // Touch scrolling already gets native CSS snap. Desktop uses one explicit
    // transition per wheel gesture so trackpad momentum cannot skip sections.
    if (sections.length < 2 || root.dataset.snapReady === "true" || usesTouch) {
      return;
    }
    root.dataset.snapReady = "true";

    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    let locked = false;
    let wheelIntent = 0;
    let wheelDirection = 0;
    let wheelResetTimer: number | undefined;
    let wheelReleaseTimer: number | undefined;
    let waitingForWheelRelease = false;

    const resetWheelIntent = () => {
      window.clearTimeout(wheelResetTimer);
      wheelIntent = 0;
      wheelDirection = 0;
    };

    const scheduleWheelRelease = () => {
      window.clearTimeout(wheelReleaseTimer);
      wheelReleaseTimer = window.setTimeout(() => {
        waitingForWheelRelease = false;
      }, 180);
    };

    const normalizedWheelDelta = (event: WheelEvent) =>
      Math.abs(event.deltaY) *
      (event.deltaMode === WheelEvent.DOM_DELTA_LINE
        ? 16
        : event.deltaMode === WheelEvent.DOM_DELTA_PAGE
          ? window.innerHeight
          : 1);

    const closestSectionIndex = () => {
      let closestIndex = 0;
      let closestDistance = Number.POSITIVE_INFINITY;

      sections.forEach((section, index) => {
        const distance = Math.abs(section.getBoundingClientRect().top);
        if (distance < closestDistance) {
          closestDistance = distance;
          closestIndex = index;
        }
      });

      return closestIndex;
    };

    const goToSection = (index: number) => {
      const target = sections[Math.max(0, Math.min(index, sections.length - 1))];
      if (!target || Math.abs(target.getBoundingClientRect().top) < 2) return;

      locked = true;
      waitingForWheelRelease = true;
      window.clearTimeout(wheelReleaseTimer);
      root.dataset.snapAnimating = "true";

      const complete = () => {
        locked = false;
        delete root.dataset.snapAnimating;
        scheduleWheelRelease();
      };

      if (reducedMotion.matches) {
        window.scrollTo({ top: target.offsetTop, behavior: "auto" });
        complete();
        return;
      }

      gsap.killTweensOf(window);
      gsap.to(window, {
        duration: 0.72,
        ease: "power3.inOut",
        overwrite: true,
        scrollTo: { y: target.offsetTop, autoKill: false },
        onComplete: complete,
        onInterrupt: complete,
      });
    };

    window.addEventListener(
      "wheel",
      (event) => {
        if (event.ctrlKey || Math.abs(event.deltaY) < 0.5) return;
        if (locked || waitingForWheelRelease) {
          event.preventDefault();
          scheduleWheelRelease();
          return;
        }

        const currentIndex = closestSectionIndex();
        const currentSection = sections[currentIndex];
        const direction = Math.sign(event.deltaY);
        const rect = currentSection?.getBoundingClientRect();
        const delta = normalizedWheelDelta(event);
        const canScrollWithinSection = rect
          ? direction > 0
            ? rect.bottom - window.innerHeight > delta + 2
            : -rect.top > delta + 2
          : false;

        if (canScrollWithinSection) {
          resetWheelIntent();
          return;
        }

        const nextIndex = Math.max(
          0,
          Math.min(currentIndex + direction, sections.length - 1),
        );
        if (nextIndex === currentIndex) {
          resetWheelIntent();
          return;
        }

        event.preventDefault();
        if (wheelDirection !== direction) {
          wheelIntent = 0;
          wheelDirection = direction;
        }

        wheelIntent += delta;

        window.clearTimeout(wheelResetTimer);
        wheelResetTimer = window.setTimeout(resetWheelIntent, 180);

        if (wheelIntent < 60) return;

        resetWheelIntent();
        goToSection(nextIndex);
      },
      { passive: false },
    );

    document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((link) => {
      const targetId = link.hash.slice(1);
      const targetIndex = sections.findIndex((section) => section.id === targetId);
      if (targetIndex < 0) return;

      link.addEventListener("click", (event) => {
        event.preventDefault();
        window.history.pushState(null, "", link.hash);
        goToSection(targetIndex);
      });
    });
  };

  initSectionSnap();
</script>
