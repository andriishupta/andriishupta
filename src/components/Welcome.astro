<main
	class="relative grid min-h-screen items-end overflow-hidden px-8 py-16 sm:items-center sm:px-[clamp(2rem,7vw,6rem)]"
>
	<div
		aria-hidden="true"
		class="pointer-events-none fixed inset-0 opacity-[0.16] [background-image:radial-gradient(rgba(23,19,15,0.55)_0.8px,transparent_0.8px)] [background-size:22px_22px] [mask-image:linear-gradient(to_bottom,black,transparent_78%)] dark:opacity-[0.18] dark:[background-image:radial-gradient(rgba(244,240,232,0.7)_0.8px,transparent_0.8px)]"
	>
	</div>

	<section
		class="hero-motion w-full max-w-[760px]"
		aria-labelledby="hero-title"
		transition:name="hero"
	>
		<p class="mb-5 font-mono text-[0.82rem] text-light-muted dark:text-muted">andriishupta.dev</p>
		<h1
			id="hero-title"
			class="max-w-[11ch] text-[clamp(3.5rem,19vw,6rem)] leading-[0.9] tracking-normal text-light-ink dark:text-[#fffaf0] sm:text-[clamp(3.6rem,12vw,8.5rem)]"
		>
			Andrii Shupta
		</h1>
		<p class="mt-6 max-w-[660px] text-[clamp(1.25rem,2.5vw,2rem)] leading-[1.35] tracking-normal text-light-soft dark:text-paper-soft">
			Building reliable tools for AI, health systems, and distributed software.
		</p>
		<div class="mt-9 flex flex-wrap gap-3" aria-label="Primary links">
			<a
				class="inline-flex min-h-11 items-center justify-center rounded-full border border-light-ink/20 bg-light-ink px-4 text-[0.95rem] text-light-paper no-underline transition hover:-translate-y-px hover:border-light-ink/40 dark:border-paper/30 dark:bg-paper dark:text-ink dark:hover:border-paper/40 motion-reduce:transition-none motion-reduce:hover:translate-y-0"
				href="https://blog.andriishupta.dev"
				data-astro-reload
			>
				Blog
			</a>
			<a
				class="inline-flex min-h-11 items-center justify-center rounded-full border border-light-ink/15 bg-light-ink/[0.04] px-4 text-[0.95rem] text-light-ink no-underline transition hover:-translate-y-px hover:border-light-ink/35 hover:bg-light-ink/[0.08] dark:border-paper/15 dark:bg-paper/[0.04] dark:text-paper dark:hover:border-paper/35 dark:hover:bg-paper/[0.08] motion-reduce:transition-none motion-reduce:hover:translate-y-0"
				href="/links"
			>
				Links
			</a>
		</div>
	</section>
</main>

<script>
	import { animate } from 'motion/mini';

	if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
		const hero = document.querySelector('.hero-motion');

		if (hero) {
			animate(
				hero,
				{ opacity: [0, 1], transform: ['translateY(12px)', 'translateY(0)'] },
				{ duration: 0.7, ease: 'easeOut' },
			);
		}
	}
</script>
