---
import type { MarkdownHeading } from "astro";

interface Props {
  headings: MarkdownHeading[];
  mobile?: boolean;
}

const { headings, mobile = false } = Astro.props;
const visibleHeadings = headings.filter(
  ({ depth }) => depth === 2 || depth === 3,
);
---

{
  visibleHeadings.length > 0 &&
    (mobile ? (
      <details class="article-toc article-toc--mobile">
        <summary>On this page</summary>
        <ol>
          {visibleHeadings.map((heading) => (
            <li class:list={{ "article-toc__nested": heading.depth === 3 }}>
              <a href={`#${heading.slug}`} data-toc-link={heading.slug}>
                {heading.text}
              </a>
            </li>
          ))}
        </ol>
      </details>
    ) : (
      <aside class="article-toc article-toc--desktop" aria-label="Table of contents">
        <p>On this page</p>
        <ol>
          {visibleHeadings.map((heading) => (
            <li class:list={{ "article-toc__nested": heading.depth === 3 }}>
              <a href={`#${heading.slug}`} data-toc-link={heading.slug}>
                {heading.text}
              </a>
            </li>
          ))}
        </ol>
      </aside>
    ))
}
