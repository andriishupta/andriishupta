---
import ArrowRight from "@lucide/astro/icons/arrow-right";
import BlogFooter from "../../components/BlogFooter.astro";
import BlogHeader from "../../components/BlogHeader.astro";
import { copy } from "../../copy";
import {
  formatBlogDate,
  getBlogPosts,
  getPostPath,
  getReadingStats,
  hasMeaningfulUpdate,
  toIsoDate,
} from "../../lib/blog";
import Layout from "../../layouts/Layout.astro";
import "../../styles/blog.css";

const posts = await getBlogPosts();
const title = `Writing | ${copy.identity.fullName}`;
const description =
  "Technical notes by Andrii Shupta on software architecture, web development, integrations, security, and production engineering.";
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Blog",
      "@id": "https://andriishupta.dev/blog/#blog",
      url: "https://andriishupta.dev/blog",
      name: `${copy.identity.fullName} — Writing`,
      description,
      inLanguage: "en",
      author: { "@id": "https://andriishupta.dev/#person" },
      blogPost: posts.map((post) => ({
        "@type": "BlogPosting",
        headline: post.data.title,
        url: new URL(getPostPath(post), "https://andriishupta.dev").toString(),
        datePublished: toIsoDate(post.data.publishedAt),
        dateModified: toIsoDate(post.data.updatedAt ?? post.data.publishedAt),
      })),
    },
    {
      "@type": "CollectionPage",
      url: "https://andriishupta.dev/blog",
      name: title,
      isPartOf: { "@id": "https://andriishupta.dev/#website" },
      mainEntity: { "@id": "https://andriishupta.dev/blog/#blog" },
    },
  ],
};
---

<Layout
  title={title}
  description={description}
  pathname="/blog"
  image="/blog/og.png"
  imageAlt="Andrii Shupta — technical writing on software and systems"
  structuredData={structuredData}
  showThemeSwitcher={false}
  rss
>
  <BlogHeader />

  <main class="blog-index">
    <header class="blog-index__intro">
      <h1>Writing</h1>
      <p>Notes on software, systems, and the work behind them.</p>
    </header>

    <section class="blog-archive" aria-label="Articles">
      {
        posts.map((post) => {
          const stats = getReadingStats(
            post.body,
            post.data.originalReadingMinutes,
          );

          return (
            <article class="blog-entry">
              <a class="blog-entry__link" href={getPostPath(post)}>
                <div class="blog-entry__meta">
                  <time datetime={toIsoDate(post.data.publishedAt)}>
                    {formatBlogDate(post.data.publishedAt)}
                  </time>
                  {hasMeaningfulUpdate(post) && post.data.updatedAt && (
                    <span>
                      Updated {formatBlogDate(post.data.updatedAt)}
                    </span>
                  )}
                  {stats.readingMinutes > 0 && (
                    <span>
                      {stats.readingMinutes} min {stats.isStub ? "original " : ""}read
                    </span>
                  )}
                  {stats.isStub && <span>Import pending</span>}
                </div>
                <div class="blog-entry__copy">
                  <h2>{post.data.title}</h2>
                  {(post.data.subtitle || post.data.description) && (
                    <p>{post.data.subtitle ?? post.data.description}</p>
                  )}
                </div>
                <ul class="blog-entry__tags" aria-label="Topics">
                  {post.data.tags.map((tag) => (
                    <li>#{tag}</li>
                  ))}
                </ul>
                <ArrowRight class="blog-entry__arrow" aria-hidden="true" />
              </a>
            </article>
          );
        })
      }
    </section>
  </main>

  <BlogFooter />
</Layout>
