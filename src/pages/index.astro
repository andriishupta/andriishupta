---
import About from "../components/About.astro";
import Experience from "../components/Experience.astro";
import Hero from "../components/Hero.astro";
import SectionSnap from "../components/SectionSnap.astro";
import { copy, urls } from "../copy";
import Layout from "../layouts/Layout.astro";

const siteUrl = "https://andriishupta.dev";
const { seo } = copy;
const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      url: siteUrl,
      name: copy.identity.fullName,
      description: seo.description,
      inLanguage: "en",
    },
    {
      "@type": "ProfilePage",
      "@id": `${siteUrl}/#profile`,
      url: siteUrl,
      name: seo.title,
      description: seo.description,
      isPartOf: { "@id": `${siteUrl}/#website` },
      mainEntity: { "@id": `${siteUrl}/#person` },
      inLanguage: "en",
    },
    {
      "@type": "Person",
      "@id": `${siteUrl}/#person`,
      name: copy.identity.fullName,
      url: siteUrl,
      image: `${siteUrl}/og-image.png`,
      jobTitle: "Full-Stack Engineer",
      description: seo.description,
      sameAs: [urls.linkedin, urls.upwork, urls.github, urls.x, urls.blog],
      knowsAbout: seo.knowsAbout,
    },
  ],
};
---

<Layout
    title={seo.title}
    description={seo.description}
    image="/og-image.png"
    imageAlt={seo.imageAlt}
    ogType="profile"
    structuredData={structuredData}
>
    <Hero />
    <About />
    <Experience />
    <SectionSnap />
</Layout>
